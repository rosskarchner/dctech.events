<form id="event-form" hx-post="https://api.dctech.events/api/events" hx-swap="outerHTML">
    <div class="form-group">
        <label for="event-title">Event Title *</label>
        <input type="text" id="event-title" name="title" required>
        <div class="error-message" id="title-error">Please enter a valid event title</div>
    </div>
    
    <div class="form-group">
        <label for="event-description">Description *</label>
        <textarea id="event-description" name="description" rows="5" required></textarea>
        <div class="error-message" id="description-error">Please enter a description</div>
    </div>
    
    <div class="form-group">
        <label for="event-date">Date *</label>
        <input type="date" id="event-date" name="date" required>
        <div class="error-message" id="date-error">Please select a valid date</div>
    </div>
    
    <div class="form-group">
        <label for="event-time">Time <span class="optional">(optional)</span></label>
        <input type="time" id="event-time" name="time">
    </div>
    
    <div class="form-group">
        <label for="event-location">Location <span class="optional">(optional)</span></label>
        <input type="text" id="event-location" name="location" placeholder="e.g., 123 Main St, Washington DC or Virtual">
    </div>
    
    <div class="form-group">
        <label for="event-url">Event URL <span class="optional">(optional)</span></label>
        <input type="url" id="event-url" name="url" placeholder="https://example.com/event">
        <div class="error-message" id="url-error">Please enter a valid URL</div>
    </div>
    
    <button type="submit" class="btn-primary">Submit Event</button>
</form>
