<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="htmx-config" content='{"selfRequestsOnly":false}'>
    <title>{{title}}</title>
    <link rel="stylesheet" href="/static/css/main.css">
    <!-- HTMX for dynamic content loading -->
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <script src="/static/js/auth.js"></script>
    <script src="/static/js/common.js"></script>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
        }
        header {
            background-color: #f8f9fa;
            border-bottom: 1px solid #ddd;
            padding: 10px 0;
        }
        header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        nav ul {
            display: flex;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        nav ul li {
            margin-left: 20px;
        }
        nav ul li a {
            text-decoration: none;
            color: #333;
        }
        footer {
            background-color: #f8f9fa;
            border-top: 1px solid #ddd;
            padding: 20px 0;
            margin-top: 40px;
            text-align: center;
        }
        
        /* Event styles */
        .events-container {
            margin-top: 20px;
        }
        .week-navigation {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .nav-button {
            padding: 8px 16px;
            background-color: #f0f0f0;
            border-radius: 4px;
            text-decoration: none;
            color: #333;
        }
        .current-week {
            font-weight: bold;
        }
        .event-card {
            border: 1px solid #ddd;
            border-radius: 4px;
            padding: 15px;
            margin-bottom: 15px;
            background-color: #fff;
        }
        .event-date {
            color: #666;
            margin-bottom: 5px;
        }
        .event-title {
            margin: 0 0 10px 0;
        }
        .event-details {
            margin-top: 10px;
        }
        .event-time, .event-location {
            margin: 5px 0;
        }
        .event-description {
            margin: 10px 0;
            padding: 10px;
            background-color: #f9f9f9;
            border-radius: 4px;
        }
        .event-source {
            font-size: 0.8em;
            color: #666;
            margin-top: 10px;
        }
        .no-events {
            padding: 20px;
            background-color: #f9f9f9;
            border-radius: 4px;
            text-align: center;
        }
    </style>
</head>
<body>
    <header>
        <div class="container">
            <h1>DC Tech Events</h1>
            <nav>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/events">Events</a></li>
                    <li><a href="/sources">Sources</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="container">
        <h2>{{title}}</h2>
        
        {{{content}}}
    </div>

    <footer>
        <div class="container">
            <p>&copy; 2025 DC Tech Events</p>
        </div>
    </footer>
</body>
</html>
